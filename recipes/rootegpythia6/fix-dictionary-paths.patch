Strip ${CMAKE_CURRENT_LIST_DIR} prefixes from the dictionary header
list. ROOT_GENERATE_DICTIONARY embeds the literal paths into the
generated *.cxx and *_rdict.pcm, leaking the build host's checkout path
into the installed package. Pass the headers as bare filenames and add
inc/ to include_directories so ROOT's dictionary generator can resolve
them; this keeps the generated dictionary relocatable.

TODO: open upstream PR against luketpickering/ROOTEGPythia6 so we can
drop this patch.

--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -43,10 +43,11 @@ else()
   find_package(Pythia6 REQUIRED)
 endif()

+include_directories(${CMAKE_CURRENT_LIST_DIR}/inc)
 ROOT_GENERATE_DICTIONARY(TPythia6
-              ${CMAKE_CURRENT_LIST_DIR}/inc/TMCParticle.h
-              ${CMAKE_CURRENT_LIST_DIR}/inc/TPythia6.h
-              ${CMAKE_CURRENT_LIST_DIR}/inc/TPythia6Decayer.h
+              TMCParticle.h
+              TPythia6.h
+              TPythia6Decayer.h
               LINKDEF ${CMAKE_CURRENT_LIST_DIR}/inc/LinkDef.h
               OPTIONS --noIncludePaths)

