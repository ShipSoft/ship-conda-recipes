{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["every weekend"],
  "prConcurrentLimit": 5,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update versions in rattler-build recipes (GitHub template sources)",
      "managerFilePatterns": ["/recipe\\.yaml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "context:\\n\\s+version:\\s*\"(?<currentValue>[^\"]+)\"",
        "url:\\s*https://github\\.com/(?<packageName>[^/]+/[^/]+)/archive/"
      ],
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Update versions in rattler-build recipes (GitLab CERN template sources)",
      "managerFilePatterns": ["/recipe\\.yaml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "context:\\n\\s+version:\\s*\"(?<currentValue>[^\"]+)\"",
        "url:\\s*https://gitlab\\.cern\\.ch/(?<packageName>[^/]+/[^/]+)/-/archive/"
      ],
      "datasourceTemplate": "gitlab-tags",
      "registryUrlTemplate": "https://gitlab.cern.ch",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    }
  ],
  "packageRules": [
    {
      "description": "Use loose versioning for HEP tag schemes",
      "matchManagers": ["custom.regex"],
      "versioning": "loose"
    },
    {
      "description": "Packages pinned to commits/branches, not release tags",
      "matchPackageNames": [
        "luketpickering/ROOTEGPythia6",
        "SND-LHC/pythia6",
        "ShipSoft/data-model",
        "ShipSoft/field_service",
        "ShipSoft/geometry_service",
        "acts-project/covfie"
      ],
      "enabled": false
    }
  ]
}
